# ─── Core ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://username:password@rds-hostname.internal:5432/dbname
PORT=3000
ALLOWED_ORIGINS=https://claude.ai
QUERY_TIMEOUT_MS=30000

# ─── OAuth ──────────────────────────────────────────────────────────────────
# Set OAUTH_ENABLED=true to require Cognito JWT on all /mcp requests.
# When enabled, all COGNITO_* vars below are required.
OAUTH_ENABLED=false

# Public URL of this server — used in WWW-Authenticate response headers
SERVER_URL=https://your-alb-domain.com

# Cognito — account 677276076027, ca-central-1
# User Pool: postgresql-mcp-pool (ca-central-1_Dg54ZeBNW)
COGNITO_ISSUER=https://cognito-idp.ca-central-1.amazonaws.com/ca-central-1_Dg54ZeBNW
COGNITO_USER_POOL_ID=ca-central-1_Dg54ZeBNW
COGNITO_JWKS_URL=https://cognito-idp.ca-central-1.amazonaws.com/ca-central-1_Dg54ZeBNW/.well-known/jwks.json
COGNITO_DOMAIN=https://postgresql-mcp-auth.auth.ca-central-1.amazoncognito.com
COGNITO_TOKEN_ENDPOINT=https://postgresql-mcp-auth.auth.ca-central-1.amazoncognito.com
COGNITO_SCOPE=https://postgresql-mcp/read

# Use the INTERACTIVE client for Claude Desktop + Claude.ai web OAuth flow
# Client name: postgresql-mcp-interactive
COGNITO_CLIENT_ID=2f9lbmh0b2jfflidpljnp3jisd
COGNITO_CLIENT_SECRET=<postgresql-mcp-interactive client secret>

# M2M client (postgresql-mcp-m2m) — for direct programmatic/API access
# COGNITO_CLIENT_ID=57fb77gthrfdhtu7j50p4t5p17
# COGNITO_CLIENT_SECRET=<postgresql-mcp-m2m client secret>
